PORT=5000
NODE_ENV=development
JWT_SECRET=change-me-in-production

# When MongoDB runs via this repo's docker-compose (mongodb service), use 127.0.0.1 from your machine:
#   docker compose up -d mongodb
MONGODB_URI=mongodb://placement:admin123@127.0.0.1:27017/placement_db?authSource=admin

# Plain local MongoDB (no auth) example:
# MONGODB_URI=mongodb://127.0.0.1:27017/placement_db

# Google Gemini (Student Assistant chat + AI Resume Analyzer). Never commit real keys.
# GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
